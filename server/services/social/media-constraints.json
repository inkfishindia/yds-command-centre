{
  "instagram": {
    "name": "Instagram",
    "media": {
      "image": {
        "allowedAspectRatios": ["1:1", "4:5", "1.91:1"],
        "minAspectRatio": 0.8,
        "maxAspectRatio": 1.91,
        "maxCount": 10,
        "maxFileSizeMB": 30,
        "formats": ["jpg", "jpeg", "png"]
      },
      "video": {
        "maxDurationSeconds": 60,
        "maxFileSizeMB": 650,
        "formats": ["mp4", "mov"],
        "minWidth": 720,
        "maxWidth": 1080
      }
    },
    "caption": {
      "maxLength": 2200,
      "minLength": 1
    },
    "hashtags": {
      "maxCount": 30
    }
  },
  "linkedin": {
    "name": "LinkedIn",
    "media": {
      "image": {
        "allowedAspectRatios": ["1.91:1", "1:1"],
        "minAspectRatio": 1.3,
        "maxAspectRatio": 2.13,
        "maxCount": 9,
        "maxFileSizeMB": 5,
        "formats": ["jpg", "jpeg", "png", "gif"]
      },
      "video": {
        "maxDurationSeconds": 600,
        "maxFileSizeMB": 5,
        "formats": ["mp4", "mov"],
        "minWidth": 1920,
        "maxWidth": 3840
      }
    },
    "caption": {
      "maxLength": 3000,
      "minLength": 1
    },
    "hashtags": {
      "maxCount": 3
    }
  }
}