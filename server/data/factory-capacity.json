      "operators": 2,
      "formula": "min(sum_of_printers, curer_capacity) — capped by sub-bottleneck CURER-01",
      "rules": [
        { "type": "sub_bottleneck", "bottleneck_machine": "CURER-01", "description": "Zone output capped by curer capacity, not printer sum" },
        { "type": "uses_shared_resource", "resource": "FUSING", "description": "Depends on Fusing Bay availability" }
      ]
    },
