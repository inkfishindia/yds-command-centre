  "formulas": {
    "_note": "Read-only. Documents calculation methods used by the capacity engine.",
    "standard_zone": "theoretical_pcs_per_hour × (available_minutes / 60) × efficiency_factor",
    "qc_pack_combined": "operators × (shift_minutes / qc_combined_minutes_per_piece) × qc_efficiency",
    "qc_pack_separated": "min(qc_operators × shift_minutes / 3.5, pack_operators × shift_minutes / 3.5) × qc_efficiency",
    "sub_bottleneck": "DTG zone capped by CURER-01 throughput (160 pcs/shift) even though sum of DTG printers = 300 pcs/shift",
    "shared_resources": "Fusing Bay presses (FUSE-01..04) are shared across DTG, DTF, and SUB zones",
    "binding_constraint": "factory_throughput = min(all zone capacities) — the single lowest zone determines the overall ceiling",
    "load_ratio": "demand / capacity — thresholds: OK < 70%, Approaching 70-89%, At Risk 90-99%, Over >= 100%"
  }
