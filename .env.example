# Copy this to .env and fill in your keys
ANTHROPIC_API_KEY=sk-ant-...
NOTION_TOKEN=ntn_...
PORT=3000
DATABASE_URL=postgres://user:password@localhost:5432/yds_command_centre
DATABASE_SSL=false
READ_MODEL_SYNC_ENABLED=true

# Anthropic chat model — defaults to Sonnet 4.6 (cheaper, fast).
# Switch to claude-opus-4-7 only for sessions needing deep reasoning.
MODEL=claude-sonnet-4-6

# Path to Colin's workspace (business operating system)
# Defaults to ../dan if not set
COLIN_WORKSPACE=../dan

# Google Ads reporting spreadsheet
GOOGLE_ADS_SPREADSHEET_ID=1zJVYckVMX0VBcwgr7VBzkYZ8dSrMPHoDmgpQaRlzH1s

# AI Provider toggle: 'anthropic' (default) or 'deepseek'
PROVIDER=anthropic
DEEPSEEK_API_KEY=nvapi-...
DEEPSEEK_BASE_URL=https://integrate.api.nvidia.com/v1
DEEPSEEK_MODEL=deepseek-ai/deepseek-v3-2

# OpenCode CLI (.opencode/) reads this for the nvidia provider via opencode.json.
# Same key as DEEPSEEK_API_KEY above — set both, or share by exporting once.
NVIDIA_API_KEY=nvapi-...
