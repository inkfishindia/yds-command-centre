# Copy this to .env and fill in your keys
ANTHROPIC_API_KEY=sk-ant-...
NOTION_TOKEN=ntn_...
PORT=3000
DATABASE_URL=postgres://user:password@localhost:5432/yds_command_centre
DATABASE_SSL=false
READ_MODEL_SYNC_ENABLED=true

# Anthropic chat model — defaults to Sonnet 4.6 (cheaper, fast).
# Switch to claude-opus-4-7 only for sessions needing deep reasoning.
MODEL=claude-sonnet-4-6

# Path to Colin's workspace (business operating system)
# Defaults to ../dan if not set
COLIN_WORKSPACE=../dan

# Google Ads reporting spreadsheet
GOOGLE_ADS_SPREADSHEET_ID=1zJVYckVMX0VBcwgr7VBzkYZ8dSrMPHoDmgpQaRlzH1s

# AI Provider toggle: 'anthropic' (default) or 'deepseek'
PROVIDER=anthropic
DEEPSEEK_API_KEY=nvapi-...
DEEPSEEK_BASE_URL=https://integrate.api.nvidia.com/v1
DEEPSEEK_MODEL=deepseek-ai/deepseek-v3-2

# OpenCode CLI (.opencode/) reads this for the nvidia provider via opencode.json.
# Same key as DEEPSEEK_API_KEY above — set both, or share by exporting once.
NVIDIA_API_KEY=nvapi-...


# ── Marketing DBs (Hub A — IG playbook v1, Hub B — Marketing Log + Campaign Decisions) ──
# DOCUMENTATION ONLY. Per Decision #100 (2026-05-02) and Decision #102, these IDs are
# hardcoded in server/services/notion/databases.js (lines 38-45). The runtime does NOT
# read these env vars. Listed here so the env file matches the canonical DB registry
# in docs/marketing/NOTION-SETUP.md §1. Do not add reads of these vars in code without
# first reverting the hardcoded constants.
IG_PERFORMANCE_DB_ID=5959753fb4ff4b7a9d16c4e1ec46a811
HOOK_PATTERN_LOG_DB_ID=3a32a0aea45b4537b73e76015c8ec9e0
TEMPLATE_LIBRARY_DB_ID=ff498859fead4048b9d6ea250b4ffc19
APPROVALS_LOG_DB_ID=352b4779a93742e59553f9247317ed94
WEEKLY_OPS_LOG_DB_ID=450968bb4a5042d4bab2590d99b3d03d
MARKETING_LOG_DB_ID=3ca17008a2994dcfa662300438a9e295
CAMPAIGN_DECISIONS_DB_ID=36f79d19dbfe4fddb593f919db15e8b2